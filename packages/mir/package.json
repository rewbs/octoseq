{
  "name": "@octoseq/mir",
  "version": "0.1.0",
  "description": "WebGPU-accelerated Music Information Retrieval (MIR) library (skeleton)",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runner/runMir": {
      "types": "./dist/runner/runMir.d.ts",
      "import": "./dist/runner/runMir.js"
    },
    "./runner/workerProtocol": {
      "types": "./dist/runner/workerProtocol.d.ts",
      "import": "./dist/runner/workerProtocol.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint -c eslint.config.mjs .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vite": "8.1.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "fft.js": "^4.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rewbs/octoseq.git",
    "directory": "packages/mir"
  }
}
